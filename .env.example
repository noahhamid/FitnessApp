# Server (Hono + Prisma)
DATABASE_URL=
DIRECT_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://192.168.0.150:3000
# Gemini is server-side only. Keep this key private and never expose it to the client bundle.
GEMINI_API_KEY=
PORT=3000

# Expo client — use your machine's LAN IP so physical devices can reach the API
EXPO_PUBLIC_API_URL=http://192.168.0.150:3000
EXPO_PUBLIC_BETTER_AUTH_URL=http://192.168.0.150:3000
